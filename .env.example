# Copy this file to `.env`. docker compose loads it automatically.

# --- ByteHide Runtime (REQUIRED) ---
# ByteHide Runtime project token. Required: the container will not start without it.
BYTEHIDE_MONITOR_TOKEN=bh_xxxxxxxxxxxxxxxxxxxxxxxx

# Session blocking: 0 = block only the offending request; 1 = block the whole attacker session.
# Keep 0 for the scorecard so a detected attack does not 403 later (benign) requests by cascade.
BYTEHIDE_SESSION_BLOCK=0

# --- Runtime sizing (optional) ---
BENCH_MAX_HEAP=4g
BENCH_MEM_LIMIT=6g

# --- Networking (optional) ---
# Host port mapped to the container's HTTPS port (9443 inside the container).
BENCH_HOST_PORT=9443
